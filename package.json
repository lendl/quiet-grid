{
  "name": "quiet-grid",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "engine": "tsx --tsconfig src/engine/tsconfig.json src/engine/index.ts",
    "lint": "eslint src App.tsx",
    "lint:fix": "eslint src App.tsx --fix",
    "test:regression": "node tests/regression/run.cjs",
    "typecheck:app": "tsc --noEmit",
    "typecheck:engine": "tsc --noEmit --project src/engine/tsconfig.json",
    "check:wordsearch": "tsx --tsconfig src/engine/tsconfig.json src/engine/checkWordSearchCatalog.ts"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-vector-icons/ionicons": "^13.1.2",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/material-top-tabs": "^7.4.28",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.17.6",
    "@react-navigation/stack": "^7.9.3",
    "expo": "~56.0.8",
    "react": "19.2.3",
    "react-native": "^0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-paper": "^5.15.3",
    "react-native-popover-view": "^6.1.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@expo/cli": "56.1.13",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/react": "~19.2.0",
    "babel-preset-expo": "~57.0.1",
    "better-sqlite3": "^12.8.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "private": true,
  "overrides": {
    "uuid": "^11.1.1"
  }
