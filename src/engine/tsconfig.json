{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "rootDir": "..",
    "outDir": "../../dist/engine",
    "paths": {
      "react-native": ["../stubs/react-native"],
      "react-native/*": ["../stubs/react-native"]
    }
  },
  "include": ["./**/*.ts"]
}
